# Composio AI Research Agent - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Composio AI Research Agent
APP_VERSION=0.1.0
DEBUG=false

# ============================================================================
# Output Configuration
# ============================================================================
OUTPUT_DIR=output
RAW_OUTPUT_DIR=output/raw
VERIFIED_OUTPUT_DIR=output/verified
REPORTS_DIR=output/reports
CHARTS_DIR=output/charts

# ============================================================================
# Research Settings
# ============================================================================
MAX_RETRIES=3
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=1.0

# ============================================================================
# LLM Provider API Keys (Optional - Add as needed)
# ============================================================================
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# Search/Scraping API Keys (Optional - Add as needed)
# ============================================================================
# Serper (Google Search API)
SERPER_API_KEY=your_serper_api_key_here

# ============================================================================
# Browser Automation
# ============================================================================
# Playwright settings
PLAYWRIGHT_HEADLESS=true

# ============================================================================
# Logging
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/research_agent.log

# ============================================================================
# Database (Optional - for future use)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/research_db

# ============================================================================
# Notification Settings (Optional - for future use)
# ============================================================================
# SLACK_WEBHOOK_URL=your_slack_webhook_url
# EMAIL_NOTIFICATIONS=true
# EMAIL_TO=your_email@example.com